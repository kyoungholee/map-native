EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=kpow7seqvx

# WebView 지도 인증 — 콘솔 "Web 서비스 URL" (포트·경로 없이 호스트만):
#   http://localhost
#   http://127.0.0.1
# Android 에뮬레이터는 127.0.0.1 기준으로 인증됩니다.
# maps.js 파라미터는 ncpKeyId (구 ncpClientId 아님)

