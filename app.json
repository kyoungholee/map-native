{
  "expo": {
    "name": "건설현장 베타",
    "slug": "dooson-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dooson.map.beta",
